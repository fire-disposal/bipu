# ==============================================
# Bipupu Project Environment Variables (Local Dev)
# ==============================================

# --- Backend Configuration ---
PROJECT_NAME=FastAPI Backend
VERSION=1.0.0
DESCRIPTION=FastAPI + PostgreSQL + Redis + Celery Backend
DEBUG=True
SECRET_KEY=jasidjiwiddsajodjojdsmsmmm
ALLOWED_HOSTS=["*"]

# --- Database Configuration ---
# 本地开发通常连接到 localhost
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bipupu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Redis Configuration ---
# 本地开发通常连接到 localhost
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- pgAdmin Configuration ---
PGADMIN_EMAIL=admin@bipupu.com
PGADMIN_PASSWORD=admin

# --- Timezone ---
TZ=Asia/Shanghai
TIMEZONE=Asia/Shanghai

# --- Logging ---
# 本地开发使用 text 格式更易读
LOG_LEVEL=INFO
LOG_FORMAT=text

# --- File Upload ---
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
