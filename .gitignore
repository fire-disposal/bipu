# ==============================================================================
# 1. 全局配置 (OS & IDE)
# ==============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.iml

# 环境变量与机密文件
.env
.env.*
!.env.example
*.pem
*.key

# ==============================================================================
# 2. BACKEND (Python) 优化
# ==============================================================================
# 字节码与缓存
**/__pycache__/
**/*.py[cod]
**/*.so
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/

# 虚拟环境 (精简为通用的名称)
.venv/
venv/
ENV/
backend/.python-version

# 构建与安装包
backend/build/
backend/dist/
backend/*.egg-info/
backend/uv.lock

# 业务相关 (日志与上传)
backend/logs/
backend/uploads/
backend/db.sqlite3

# ==============================================================================
# 3. FLUTTER 优化
# ==============================================================================
# Flutter/Dart 核心缓存
flutter/.dart_tool/
flutter/.flutter-plugins
flutter/.flutter-plugins-dependencies
flutter/.pub-cache/
flutter/build/

# 这里的 lock 文件建议保留（不忽略），除非你有特殊需求
# 因为 lock 文件保证了团队成员依赖版本的一致性
# flutter/pubspec.lock 

# Android 特定
flutter/android/local.properties
flutter/android/key.properties
flutter/android/.gradle/
flutter/android/app/src/main/res/raw/
flutter/android/*.jks

# iOS 特定
flutter/ios/.symlinks/
flutter/ios/Pods/
flutter/ios/DerivedData/
flutter/ios/Flutter/ephemeral/
flutter/ios/Flutter/Generated.xcconfig
flutter/ios/Flutter/flutter_export_environment.sh

# Windows 平台的本地/临时配置
flutter/windows/flutter/ephemeral/
flutter/windows/flutter/generated_config.cmake
# ==============================================================================
# 4. 其他通用
# ==============================================================================
*.log
*.tmp
node_modules/