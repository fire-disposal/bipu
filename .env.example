# ===================================================================
# Bipupu 应用配置示例文件
# ===================================================================
# 复制此文件为 .env 并根据实际情况修改配置
# 注意：生产环境请使用强密码和密钥

# -------------------------------------------------------------------
# 基础应用配置
# -------------------------------------------------------------------
PROJECT_NAME=Bipupu Backend
VERSION=1.0.0
DESCRIPTION=FastAPI + PostgreSQL + Redis + Celery Backend
DEBUG=false

# -------------------------------------------------------------------
# 安全配置 (必填 - 生产环境务必修改)
# -------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------------------------------
# 数据库配置 (必填)
# -------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-postgres-password
POSTGRES_DB=bipupu
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# -------------------------------------------------------------------
# Redis 配置 (必填)
# -------------------------------------------------------------------
REDIS_PASSWORD=your-strong-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# -------------------------------------------------------------------
# CORS 配置
# -------------------------------------------------------------------
ALLOWED_HOSTS=["*"]
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8084", "http://localhost:8080"]

# -------------------------------------------------------------------
# 日志配置
# -------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -------------------------------------------------------------------
# 分页和文件上传配置
# -------------------------------------------------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# -------------------------------------------------------------------
# 时区配置
# -------------------------------------------------------------------
TZ=Asia/Shanghai
TIMEZONE=Asia/Shanghai

# -------------------------------------------------------------------
# 容器角色配置 (用于 Celery)
# -------------------------------------------------------------------
CONTAINER_ROLE=backend

# -------------------------------------------------------------------
# pgAdmin 配置 (可选 - 仅在使用 pgadmin 服务时)
# -------------------------------------------------------------------
PGADMIN_EMAIL=admin@bipupu.com
PGADMIN_PASSWORD=your-pgadmin-password

# -------------------------------------------------------------------
# 邮件配置 (可选 - 用于邮件通知功能)
# -------------------------------------------------------------------
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-email-password
# SMTP_TLS=true
# FROM_EMAIL=noreply@bipupu.com

# -------------------------------------------------------------------
# 监控和告警配置 (可选)
# -------------------------------------------------------------------
# SENTRY_DSN=your-sentry-dsn-url
# PROMETHEUS_ENABLED=false
# GRAFANA_ENABLED=false

# -------------------------------------------------------------------
# Flutter 移动端配置 (可选)
# -------------------------------------------------------------------
# FLUTTER_API_BASE_URL=http://localhost:8084/api
# FLUTTER_WEBSOCKET_URL=ws://localhost:8084/ws