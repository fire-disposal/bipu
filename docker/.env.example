# ==============================================
# Bipupu Project Environment Variables
# ==============================================

# --- Backend Configuration ---
PROJECT_NAME=Bipupu Backend
VERSION=1.0.0
DESCRIPTION=FastAPI + PostgreSQL + Redis + Celery Backend
DEBUG=True
# 生产环境请务必修改此密钥
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALLOWED_HOSTS=["*"]

# --- Database Configuration ---
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=bipupu
POSTGRES_USER=postgres
# 生产环境请务必修改此密码
POSTGRES_PASSWORD=postgres

# --- Redis Configuration ---
REDIS_HOST=redis
REDIS_PORT=6379
# 如果留空，Redis将不设置密码（不推荐用于生产环境）
REDIS_PASSWORD=

# --- pgAdmin Configuration ---
PGADMIN_EMAIL=admin@bipupu.com
PGADMIN_PASSWORD=admin

# --- Timezone ---
TZ=Asia/Shanghai
TIMEZONE=Asia/Shanghai

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- File Upload ---
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads