# FastAPI应用配置
PROJECT_NAME=Bipupu Backend
VERSION=1.0.0
DESCRIPTION=FastAPI + PostgreSQL + Redis + Celery Backend
DEBUG=false

# 安全配置
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 数据库配置
POSTGRES_PASSWORD=1919810
DATABASE_URL=postgresql://postgres:1919810@db:5432/bipupu

# Redis配置
REDIS_PASSWORD=114514
REDIS_URL=redis://:114514@redis:6379/0
CELERY_BROKER_URL=redis://:114514@redis:6379/1
CELERY_RESULT_BACKEND=redis://:114514@redis:6379/2

# CORS配置
ALLOWED_HOSTS=["*"]

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 文件上传配置
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# 时区配置
TZ=Asia/Shanghai
TIMEZONE=Asia/Shanghai

# 容器角色配置（用于Celery）
CONTAINER_ROLE=backend